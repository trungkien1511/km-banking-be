# =========================================================================
# KM BANK - Spring Boot Backend .gitignore
# =========================================================================

# --- Compiled class files ---
*.class

# --- Log files ---
*.log
logs/

# --- Blueprints and Guides ---
login_flow_guide.md

# --- Package Files ---
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# --- Maven Build Directory ---
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.restore
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
# Avoid ignoring Maven Wrapper itself
!.mvn/wrapper/maven-wrapper.jar
!mvnw
!mvnw.cmd

# --- IntelliJ IDEA ---
.idea/
*.iml
*.iws
*.ipr
out/

# --- Eclipse ---
.settings/
.classpath
.project
.factorypath

# --- NetBeans ---
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# --- VS Code ---
.vscode/

# --- OS/System Files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Secrets and Environment Configurations ---
.env
.env.local
.env.*
application-local.properties
application-dev.properties.local
*.pem
*.key
*.p12
*.jks
